        <div class="lane-markers"></div>
    </div>

    <script>
        // Efficiently render the floors for both towers
        const build = (id, floors) => {
            const el = document.getElementById(id);
            for(let i=0; i<floors; i++) {
                const f = document.createElement('div');
                f.className = 'floor';
                el.appendChild(f);
            }
        }

        build('t1', 55); // Tall tower
        build('t2', 48); // Short tower
    </script>
